authorization_url = https://login.xero.com/identity/connect/authorize
client_id = clientid
client_secret = clinetsecret
tenant_id = d9e3104a-1995-4ab7-b3f7-c889b9e7338a
# Need accounting.transactions for Invoices, accounting.settings for Accounts,
# and accounting.contacts for Contacts.
scope = offline_access accounting.transactions accounting.settings accounting.contacts
state = some_random_value
tenant_url = http://localhost{port}/connections
token_url = http://localhost{port}/connect/token
invoice_url = http://localhost{port}/api.xro/2.0/Invoices
account_url = http://localhost{port}/api.xro/2.0/Accounts/
contact_url = http://localhost{port}/api.xro/2.0/Contacts
payment_url = http://localhost{port}/api.xro/2.0/Payments
